  <div class="modal">
    <div class="modal-title">Editar meta</div>
    <input type="hidden" id="edit-goal-id" />
    <div class="form-row"><div class="form-group"><label class="form-label">Nome</label><input class="form-input" id="edit-goal-name" type="text" /></div></div>
