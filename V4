<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>FinançasPRO</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  /* ─── LOGIN SCREEN ─── */
  @import url('https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap');
  #login-screen {
    display: flex;
    min-height: 100vh;
    background: #f0ede6;
    align-items: center;
    justify-content: center;
    font-family: 'DM Sans', system-ui, sans-serif;
  }
  .login-card {
    background: #fff;
    border: 1px solid #e0dbd0;
    border-radius: 18px;
    padding: 40px 36px;
    width: 400px;
    max-width: 95vw;
    box-shadow: 0 6px 32px rgba(45,74,43,0.10);
  }
  .login-logo { display: flex; align-items: center; gap: 10px; margin-bottom: 28px; }
  .login-logo-mark { width: 36px; height: 36px; background: #2d4a2b; border-radius: 9px; display: flex; align-items: center; justify-content: center; color: #a4ac86; font-size: 17px; font-weight: 700; }
  .login-logo-text { font-family: 'Lora', serif; font-size: 20px; font-weight: 700; color: #1e2d1c; }
  .login-title { font-family: 'Lora', serif; font-size: 22px; font-weight: 700; color: #1e2d1c; margin-bottom: 6px; }
  .login-subtitle { font-size: 13px; color: #94a18e; margin-bottom: 28px; }
  .login-tabs { display: flex; background: #f0ede6; border-radius: 9px; padding: 3px; margin-bottom: 24px; }
  .login-tab { flex: 1; text-align: center; padding: 8px; border-radius: 7px; font-size: 13px; font-weight: 600; cursor: pointer; color: #7d8471; border: none; background: transparent; font-family: inherit; transition: all .15s; }
  .login-tab.active { background: #fff; color: #2d4a2b; box-shadow: 0 1px 4px rgba(45,74,43,0.12); }
  .login-field { margin-bottom: 14px; }
  .login-label { font-size: 12px; font-weight: 600; color: #5a6655; display: block; margin-bottom: 5px; }
  .login-input { width: 100%; border: 1px solid #e0dbd0; border-radius: 8px; padding: 10px 13px; font-size: 14px; color: #1e2d1c; outline: none; font-family: inherit; transition: border-color .15s; background: #faf9f6; }
  .login-input:focus { border-color: #7d8471; }
  .login-btn { width: 100%; background: #2d4a2b; color: #faf9f6; border: none; border-radius: 8px; padding: 12px; font-size: 14px; font-weight: 700; cursor: pointer; font-family: inherit; margin-top: 6px; transition: filter .15s; }
  .login-btn:hover { filter: brightness(1.1); }
  .login-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .login-error { background: #fdf0ee; color: #a0200e; border: 1px solid #f5c5be; border-radius: 7px; padding: 10px 13px; font-size: 12px; margin-bottom: 14px; display: none; }
  .login-success { background: #e8f5ee; color: #2d6a4f; border: 1px solid #b6d9c8; border-radius: 7px; padding: 10px 13px; font-size: 12px; margin-bottom: 14px; display: none; }
  .login-divider { text-align: center; color: #94a18e; font-size: 12px; margin: 16px 0; position: relative; }
  .login-divider::before { content:''; position:absolute; top:50%; left:0; right:0; height:1px; background:#e0dbd0; }
  .login-divider span { background: #fff; padding: 0 12px; position: relative; }
  .login-google { width: 100%; background: #faf9f6; color: #1e2d1c; border: 1px solid #e0dbd0; border-radius: 8px; padding: 11px; font-size: 13px; font-weight: 600; cursor: pointer; font-family: inherit; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background .15s; }
  .login-google:hover { background: #f0ede6; }
  #app-screen { display: none; }
  .supabase-config-notice {
    background: #faf5e8; color: #7a5a00; border: 1px solid #e8d9a0;
    border-radius: 8px; padding: 12px 14px; font-size: 12px; margin-bottom: 16px;
    line-height: 1.6;
  }
  .supabase-config-notice strong { display: block; margin-bottom: 4px; }
</style>
<style>
  /* ══════════════════════════════════════════
     FOREST CANOPY THEME
     Primary: #2d4a2b  Sage: #7d8471  Olive: #a4ac86  Ivory: #faf9f6
     Fonts: 'Lora' (headers) + 'DM Sans' (body)
  ══════════════════════════════════════════ */
  @import url('https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap');

  :root {
    --primary:   #2d4a2b;
    --primary-light: #3d6438;
    --sage:      #7d8471;
    --olive:     #a4ac86;
    --olive-light: #d4d9c4;
    --ivory:     #faf9f6;
    --ivory-dark: #f0ede6;
    --ivory-border: #e0dbd0;
    --text:      #1e2d1c;
    --text-mid:  #5a6655;
    --text-soft: #94a18e;
    --income:    #2d6a4f;
    --income-bg: #e8f5ee;
    --expense:   #a0200e;
    --expense-bg:#fdf0ee;
    --warn:      #8a4a00;
    --done:      #1d3a6b;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Sans', system-ui, sans-serif; background: var(--ivory); color: var(--text); font-size: 14px; }

  /* ─── HEADER ─── */
  header { background: var(--primary); border-bottom: none; padding: 0 28px; height: 54px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; box-shadow: 0 1px 12px rgba(45,74,43,0.18); }
  .logo { display: flex; align-items: center; gap: 8px; }
  .logo-mark { width: 28px; height: 28px; background: var(--olive); border-radius: 7px; display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 13px; font-weight: 700; }
  .logo-text { font-family: 'Lora', serif; font-weight: 700; font-size: 16px; color: var(--ivory); }
  nav { display: flex; gap: 2px; }
  nav a { color: var(--olive-light); text-decoration: none; border-radius: 6px; padding: 6px 13px; font-size: 13px; cursor: pointer; transition: all .15s; font-weight: 400; }
  nav a.active { background: rgba(164,172,134,0.2); color: var(--ivory); font-weight: 600; }
  nav a:hover:not(.active) { color: var(--ivory); background: rgba(255,255,255,0.08); }
  .header-actions { display: flex; gap: 8px; align-items: center; }
  .btn { border: none; border-radius: 7px; padding: 7px 16px; font-size: 13px; font-weight: 600; cursor: pointer; font-family: inherit; transition: all .15s; }
  .btn:hover { filter: brightness(1.1); }
  .btn-primary { background: var(--olive); color: var(--primary); }
  .btn-purple  { background: rgba(255,255,255,0.15); color: var(--ivory); border: 1px solid rgba(255,255,255,0.25); }

  /* ─── PAGES ─── */
  .page { display: none; }
  .page.active { display: block; }
  main { max-width: 1080px; margin: 0 auto; padding: 28px 20px; }
  .page-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px; flex-wrap: wrap; gap: 12px; }
  .page-title { font-family: 'Lora', serif; font-size: 20px; font-weight: 700; letter-spacing: -0.3px; margin-bottom: 2px; color: var(--text); }
  .page-sub { font-size: 12px; color: var(--text-soft); }

  /* ─── COMMON ─── */
  .period-btn { background: transparent; color: var(--text-soft); border: 1px solid var(--ivory-border); border-radius: 6px; padding: 5px 14px; font-size: 12px; font-weight: 500; cursor: pointer; font-family: inherit; transition: all .15s; }
  .period-btn.active { background: var(--primary); color: var(--ivory); border-color: var(--primary); }
  .periods { display: flex; gap: 8px; margin-bottom: 22px; flex-wrap: wrap; }

  .stats { display: flex; gap: 14px; margin-bottom: 18px; flex-wrap: wrap; }
  .stat-card { background: #fff; border: 1px solid var(--ivory-border); border-radius: 12px; padding: 16px 20px; flex: 1; min-width: 140px; }
  .stat-label { font-size: 10px; font-weight: 600; color: var(--text-soft); letter-spacing: 0.6px; text-transform: uppercase; margin-bottom: 6px; }
  .stat-value { font-family: 'Lora', serif; font-size: 22px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 2px; }
  .stat-sub { font-size: 11px; color: var(--text-soft); }

  .table-card { background: #fff; border: 1px solid var(--ivory-border); border-radius: 12px; overflow: hidden; }
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; min-width: 540px; }
  thead tr { border-bottom: 1px solid var(--ivory-dark); background: var(--ivory); }
  th { padding: 11px 16px; text-align: left; color: var(--text-soft); font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: 0.4px; white-space: nowrap; cursor: pointer; user-select: none; }
  th:hover { color: var(--sage); }
  tbody tr { border-bottom: 1px solid var(--ivory-dark); transition: background .1s; }
  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: var(--ivory); }
  td { padding: 11px 16px; }
  .date-cell { color: var(--text-soft); font-size: 12px; white-space: nowrap; }
  .badge { margin-left: 5px; font-size: 10px; font-weight: 700; }
  .badge-prev   { color: var(--sage); }
  .badge-future { color: var(--sage); }
  .tag { display: inline-block; border-radius: 5px; padding: 2px 9px; font-size: 11px; font-weight: 600; }
  .tag-income  { background: var(--income-bg); color: var(--income); }
  .tag-expense { background: var(--expense-bg); color: var(--expense); }
  .tag-unica   { background: var(--ivory-dark); color: var(--text-mid); }
  .tag-parc    { background: #eef0e8; color: var(--sage); }
  .tag-fixa    { background: #e6ede5; color: var(--primary); }
  .cat-cell { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text-mid); }
  .dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .val-income  { font-weight: 600; color: var(--income);  white-space: nowrap; }
  .val-expense { font-weight: 600; color: var(--expense); white-space: nowrap; }
  .desc-cell { color: var(--text-mid); }
  .empty { color: var(--olive-light); }
  .actions { display: flex; gap: 6px; }
  .btn-edit { background: var(--ivory); color: var(--text-mid); border: 1px solid var(--ivory-border); border-radius: 6px; padding: 4px 10px; font-size: 12px; font-weight: 500; cursor: pointer; font-family: inherit; }
  .btn-del  { background: var(--expense-bg); color: var(--expense); border: 1px solid #f5c5be; border-radius: 6px; padding: 4px 10px; font-size: 12px; font-weight: 500; cursor: pointer; font-family: inherit; }
  .table-footer { margin-top: 10px; font-size: 12px; color: var(--text-soft); display: flex; gap: 16px; flex-wrap: wrap; }
  .table-footer .green { color: var(--income);  font-weight: 600; }
  .table-footer .red   { color: var(--expense); font-weight: 600; }

  /* ─── FILTERS ─── */
  .filters { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }
  .search-box { display: flex; align-items: center; gap: 8px; background: #fff; border: 1px solid var(--ivory-border); border-radius: 7px; padding: 7px 12px; flex: 1; min-width: 160px; }
  .search-box input { border: none; outline: none; font-size: 13px; color: var(--text); background: transparent; width: 100%; font-family: inherit; }
  select { background: #fff; border: 1px solid var(--ivory-border); border-radius: 7px; padding: 7px 11px; font-size: 13px; color: var(--text-mid); outline: none; cursor: pointer; font-family: inherit; }

  /* ─── DASHBOARD CHART ─── */
  .chart-card { background: #fff; border: 1px solid var(--ivory-border); border-radius: 12px; padding: 20px 22px; margin-bottom: 14px; }
  .chart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; flex-wrap: wrap; gap: 10px; }
  .chart-title { font-family: 'Lora', serif; font-size: 13px; font-weight: 600; color: var(--text); }
  .chart-filters { display: flex; gap: 6px; }
  .fake-chart { display: flex; align-items: flex-end; gap: 10px; height: 160px; padding: 0 4px; }
  .chart-group { display: flex; gap: 3px; align-items: flex-end; flex: 1; }
  .bar { border-radius: 4px 4px 0 0; min-width: 12px; }
  .bar-income  { background: var(--primary); }
  .bar-expense { background: var(--olive); }
  .bar-proj    { opacity: 0.35; }
  .chart-x { display: flex; gap: 10px; margin-top: 8px; padding: 0 4px; }
  .chart-x span { flex: 1; text-align: center; font-size: 10px; color: var(--text-soft); }
  .chart-legend { display: flex; gap: 16px; justify-content: flex-end; margin-top: 8px; }
  .legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--text-soft); }
  .legend-dot { width: 10px; height: 10px; border-radius: 2px; }

  /* ─── LIMIT BAR ─── */
  .limit-card { background: #fff; border: 1px solid var(--ivory-border); border-radius: 12px; padding: 14px 20px; margin-bottom: 14px; }
  .limit-header { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 12px; }
  .limit-label { color: var(--text-soft); }
  .limit-value { font-weight: 600; color: var(--text); }
  .bar-track { height: 6px; background: var(--ivory-dark); border-radius: 3px; }
  .bar-fill   { height: 100%; border-radius: 3px; transition: width .4s; }

  /* ─── GOALS IN DASHBOARD ─── */
  .goals-card { background: #fff; border: 1px solid var(--ivory-border); border-radius: 12px; padding: 20px 22px; }
  .sec-title { font-family: 'Lora', serif; font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 16px; }
  .goal-dash { margin-bottom: 16px; }
  .goal-dash:last-child { margin-bottom: 0; }
  .goal-row { display: flex; justify-content: space-between; margin-bottom: 6px; }
  .goal-name { font-size: 13px; font-weight: 600; }
  .goal-pct-ok   { font-size: 12px; font-weight: 700; color: var(--income); }
  .goal-pct-warn { font-size: 12px; font-weight: 700; color: var(--expense); }
  .goal-pct-done { font-size: 12px; font-weight: 700; color: var(--done); }
  .goal-track { height: 5px; background: var(--ivory-dark); border-radius: 3px; margin-bottom: 5px; }
  .goal-fill-ok   { height: 100%; border-radius: 3px; background: var(--income); }
  .goal-fill-warn { height: 100%; border-radius: 3px; background: var(--warn); }
  .goal-fill-done { height: 100%; border-radius: 3px; background: var(--done); }
  .goal-vals { display: flex; justify-content: space-between; font-size: 11px; color: var(--text-soft); }

  /* ─── CREDIT CARDS ─── */
  .cards-grid { display: flex; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
  .credit-card { border-radius: 16px; padding: 20px 22px; color: #fff; flex: 1; min-width: 220px; max-width: 300px; cursor: pointer; transition: transform .15s, box-shadow .15s; position: relative; overflow: hidden; }
  .credit-card:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(45,74,43,0.22); }
  .credit-card::before { content:''; position:absolute; width:160px; height:160px; border-radius:50%; background:rgba(255,255,255,0.07); top:-50px; right:-30px; }
  .card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
  .card-name { font-size: 13px; opacity: 0.85; }
  .card-chip { width: 26px; height: 18px; background: rgba(255,255,255,0.3); border-radius: 3px; }
  .card-spent { font-family: 'Lora', serif; font-size: 24px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 2px; }
  .card-limit-txt { font-size: 11px; opacity: 0.75; margin-bottom: 12px; }
  .card-bar-track { height: 4px; background: rgba(255,255,255,0.25); border-radius: 2px; margin-bottom: 12px; }
  .card-bar-fill { height: 100%; border-radius: 2px; background: rgba(255,255,255,0.85); }
  .card-footer { display: flex; justify-content: space-between; font-size: 11px; opacity: 0.75; margin-bottom: 10px; }
  .card-btns { display: flex; gap: 6px; }
  .card-btn { background: rgba(255,255,255,0.15); color: #fff; border: 1px solid rgba(255,255,255,0.3); border-radius: 6px; padding: 4px 10px; font-size: 11px; cursor: pointer; font-family: inherit; transition: background .15s; }
  .card-btn:hover { background: rgba(255,255,255,0.28); }
  .add-card { border: 2px dashed var(--olive-light); border-radius: 16px; padding: 20px; flex: 1; min-width: 160px; max-width: 200px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; cursor: pointer; color: var(--text-soft); background: #fff; transition: all .15s; }
  .add-card:hover { border-color: var(--sage); color: var(--sage); }

  .fatura-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; flex-wrap: wrap; gap: 8px; }
  .fatura-tabs { display: flex; gap: 6px; }
  .fatura-tab { background: transparent; color: var(--text-soft); border: 1px solid var(--ivory-border); border-radius: 6px; padding: 4px 12px; font-size: 12px; font-weight: 500; cursor: pointer; font-family: inherit; }
  .fatura-tab.active { background: var(--primary); color: var(--ivory); border-color: var(--primary); }
  .fatura-total { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; border-top: 1px solid var(--ivory-border); background: var(--ivory); }
  .fatura-total-label { font-size: 12px; color: var(--text-soft); font-weight: 600; }
  .fatura-total-value { font-family: 'Lora', serif; font-size: 15px; font-weight: 700; color: var(--expense); }

  /* ─── GOALS PAGE ─── */
  .goals-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 16px; }
  .goal-card { background: #fff; border: 1px solid var(--ivory-border); border-radius: 14px; padding: 20px 22px; }
  .goal-card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 3px; }
  .goal-card-name { font-family: 'Lora', serif; font-size: 14px; font-weight: 700; }
  .goal-type-txt { font-size: 11px; color: var(--text-soft); margin-bottom: 13px; }
  .goal-card-track { height: 7px; background: var(--ivory-dark); border-radius: 4px; margin-bottom: 8px; }
  .goal-card-fill { height: 100%; border-radius: 4px; }
  .goal-card-values { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 12px; }
  .goal-card-status { border-radius: 8px; padding: 8px 12px; font-size: 12px; margin-bottom: 14px; font-weight: 500; }
  .status-ok   { background: var(--income-bg);  color: var(--income); }
  .status-warn { background: var(--expense-bg); color: var(--expense); }
  .status-done { background: #e8edf5; color: var(--done); }
  .sim-box { border-top: 1px solid var(--ivory-border); padding-top: 12px; margin-bottom: 14px; }
  .sim-label { font-size: 11px; color: var(--text-soft); margin-bottom: 6px; }
  .sim-row { display: flex; align-items: center; gap: 8px; }
  .sim-input { background: var(--ivory); border: 1px solid var(--ivory-border); border-radius: 7px; padding: 6px 10px; font-size: 12px; color: var(--text); outline: none; font-family: inherit; width: 120px; }
  .sim-input:focus { border-color: var(--sage); }
  .sim-result { font-size: 12px; color: var(--primary); font-weight: 600; }
  .goal-actions { display: flex; gap: 8px; }
  .goal-add { border: 2px dashed var(--olive-light); border-radius: 14px; padding: 36px 20px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; cursor: pointer; color: var(--text-soft); background: #fff; transition: all .15s; }
  .goal-add:hover { border-color: var(--sage); color: var(--sage); }

  /* ─── CATEGORIES PAGE ─── */
  .type-tabs { display: flex; gap: 6px; margin-bottom: 20px; }
  .type-tab { background: #fff; border: 1px solid var(--ivory-border); border-radius: 7px; padding: 6px 16px; font-size: 13px; font-weight: 500; cursor: pointer; color: var(--text-soft); font-family: inherit; transition: all .15s; }
  .type-tab.active { background: var(--primary); color: var(--ivory); border-color: var(--primary); }
  .cats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(270px, 1fr)); gap: 14px; }
  .cat-card { background: #fff; border: 1px solid var(--ivory-border); border-radius: 14px; padding: 18px 20px; }
  .cat-header { display: flex; align-items: center; justify-content: space-between; }
  .cat-left { display: flex; align-items: center; gap: 12px; cursor: pointer; flex: 1; }
  .cat-icon-box { width: 38px; height: 38px; border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: 19px; flex-shrink: 0; }
  .cat-name { font-size: 14px; font-weight: 600; margin-bottom: 2px; }
  .cat-meta { font-size: 11px; color: var(--text-soft); }
  .cat-type-badge { font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 4px; margin-left: 5px; }
  .badge-income  { background: var(--income-bg);  color: var(--income); }
  .badge-expense { background: var(--expense-bg); color: var(--expense); }
  .badge-both    { background: #eef0e8; color: var(--sage); }
  .cat-bar-row { display: flex; align-items: center; gap: 10px; margin-top: 12px; }
  .cat-bar-track { flex: 1; height: 4px; background: var(--ivory-dark); border-radius: 2px; }
  .cat-bar-fill { height: 100%; border-radius: 2px; }
  .cat-bar-pct { font-size: 11px; color: var(--text-soft); font-weight: 500; width: 28px; text-align: right; }
  .expand-btn { font-size: 11px; color: var(--text-soft); background: none; border: none; cursor: pointer; font-family: inherit; margin-top: 8px; padding: 0; }
  .expand-btn:hover { color: var(--sage); }
  .subcats { margin-top: 12px; border-top: 1px solid var(--ivory-border); padding-top: 10px; display: none; }
  .subcats.open { display: block; }
