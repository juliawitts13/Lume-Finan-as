    <div class="form-group" style="margin-bottom:12px"><label class="form-label">Cor</label>
      <div class="color-picker" id="edit-cat-colors" style="margin-top:8px">
        <div class="color-dot" style="background:#16a34a" data-color="#16a34a"></div>
        <div class="color-dot" style="background:#dc2626" data-color="#dc2626"></div>
        <div class="color-dot" style="background:#2563eb" data-color="#2563eb"></div>
        <div class="color-dot" style="background:#ea580c" data-color="#ea580c"></div>
        <div class="color-dot" style="background:#7c3aed" data-color="#7c3aed"></div>
        <div class="color-dot" style="background:#db2777" data-color="#db2777"></div>
        <div class="color-dot" style="background:#0d9488" data-color="#0d9488"></div>
        <div class="color-dot" style="background:#ca8a04" data-color="#ca8a04"></div>
        <div class="color-dot" style="background:#1a1a2e" data-color="#1a1a2e"></div>
      </div>
