    <div class="form-group" style="margin-bottom:18px"><label class="form-label">Cor</label>
      <div class="color-picker" id="edit-card-colors" style="margin-top:8px">
        <div class="color-dot" style="background:#7c3aed" data-color="#7c3aed,#5b21b6"></div>
        <div class="color-dot" style="background:#2563eb" data-color="#2563eb,#1d4ed8"></div>
        <div class="color-dot" style="background:#16a34a" data-color="#16a34a,#15803d"></div>
        <div class="color-dot" style="background:#ea580c" data-color="#ea580c,#c2410c"></div>
        <div class="color-dot" style="background:#dc2626" data-color="#dc2626,#b91c1c"></div>
        <div class="color-dot" style="background:#0d9488" data-color="#0d9488,#0f766e"></div>
        <div class="color-dot" style="background:#db2777" data-color="#db2777,#be185d"></div>
        <div class="color-dot" style="background:#1a1a2e" data-color="#1a1a2e,#0f0f1a"></div>
      </div>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('modal-card-edit')">Cancelar</button>
      <button class="btn-save" onclick="saveEditCard()">Salvar</button>
    </div>
  </div>
</div>

<!-- Modal Editar Meta -->
