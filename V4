    <div class="form-group" style="margin-bottom:12px"><label class="form-label">Ícone</label>
      <div class="icon-picker" id="edit-cat-icons" style="margin-top:6px">
        <span class="icon-opt">💰</span><span class="icon-opt">🍔</span><span class="icon-opt">🏠</span><span class="icon-opt">🚗</span><span class="icon-opt">🎉</span><span class="icon-opt">💊</span><span class="icon-opt">📚</span><span class="icon-opt">✈️</span><span class="icon-opt">🛍️</span><span class="icon-opt">💡</span><span class="icon-opt">🎮</span><span class="icon-opt">💼</span><span class="icon-opt">🏋️</span><span class="icon-opt">🌱</span>
      </div>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('modal-cat-edit')">Cancelar</button>
      <button class="btn-save" onclick="saveEditCat()">Salvar</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
  // ══════════════════════════════════════════
  // DADOS EM MEMÓRIA (estado do app)
  // ══════════════════════════════════════════

  // Cartões: cada cartão tem id, name, limit, spent, close, due, color (gradiente)
  let cards = [
    { id: 1, name: 'Nubank',       limit: 5000, spent: 2100, close: 15, due: 22, color: '#7c3aed,#5b21b6' },
    { id: 2, name: 'Itaú Platinum', limit: 8000, spent: 850,  close: 20, due: 27, color: '#ea580c,#c2410c' },
  ];
  let nextCardId = 3;

  // Metas
  let goals = [
    { id: 1, name: 'Reserva de emergência', type: 'economy', target: 15000, current: 4200, date: '2025-12-31', monthly: 1000 },
    { id: 2, name: 'Viagem Europa',          type: 'economy', target: 8000,  current: 1500, date: '2025-10-01', monthly: 800  },
    { id: 3, name: 'Notebook novo',          type: 'control', target: 4000,  current: 3000, date: '2025-06-30', monthly: 500  },
  ];
  let nextGoalId = 4;

  // Categorias: cada categoria tem id, name, type, color, icon, pct, subs[]
  let categories = [
    { id: 1, name: 'Salário',      type: 'income',   color: '#16a34a', icon: '💰', pct: 60, txCount: 8,  subs: [] },
    { id: 2, name: 'Alimentação',  type: 'expense',  color: '#ea580c', icon: '🍔', pct: 45, txCount: 12, subs: ['Mercado', 'Restaurante'] },
    { id: 3, name: 'Moradia',      type: 'expense',  color: '#2563eb', icon: '🏠', pct: 30, txCount: 6,  subs: [] },
    { id: 4, name: 'Transporte',   type: 'expense',  color: '#7c3aed', icon: '🚗', pct: 20, txCount: 9,  subs: ['Público', 'Apps (Uber/99)', 'Combustível'] },
    { id: 5, name: 'Lazer',        type: 'expense',  color: '#db2777', icon: '🎉', pct: 15, txCount: 5,  subs: [] },
    { id: 6, name: 'Saúde',        type: 'expense',  color: '#0d9488', icon: '💊', pct: 10, txCount: 4,  subs: [] },
  ];
  let nextCatId = 7;
  let currentCatFilter = 'all';

  // ══════════════════════════════════════════
  // NAVEGAÇÃO
  // ══════════════════════════════════════════
  function nav(page) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('nav a').forEach(a => a.classList.remove('active'));
    document.getElementById('page-' + page).classList.add('active');
    document.getElementById('nav-' + page).classList.add('active');
    window.scrollTo(0, 0);
  }

  // Modais
  function openModal(id) { document.getElementById(id).classList.add('open'); }
  function closeModal(id) { document.getElementById(id).classList.remove('open'); }
  document.querySelectorAll('.modal-overlay').forEach(o => {
    o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); });
  });

  // Toast
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2500);
  }

  // Formata moeda brasileira
  function fmt(n) { return 'R$ ' + Number(n).toLocaleString('pt-BR', {minimumFractionDigits:2, maximumFractionDigits:2}); }

  // ══════════════════════════════════════════
  // CARTÕES
  // ══════════════════════════════════════════
  function renderCards() {
    const grid = document.getElementById('cards-grid');
    let html = '';
    cards.forEach(c => {
      const pct = Math.round((c.spent / c.limit) * 100);
      const [c1, c2] = c.color.split(',');
      html += `
        <div class="credit-card" style="background:linear-gradient(135deg,${c1},${c2})">
          <div class="card-top"><span class="card-name">💳 ${c.name}</span><div class="card-chip"></div></div>
          <div class="card-spent">${fmt(c.spent)}</div>
          <div class="card-limit-txt">de ${fmt(c.limit)} · ${pct}% usado</div>
          <div class="card-bar-track"><div class="card-bar-fill" style="width:${pct}%"></div></div>
          <div class="card-footer"><span>Fecha dia ${c.close}</span><span>Vence dia ${c.due}</span></div>
          <div class="card-btns">
            <button class="card-btn" onclick="openEditCard(${c.id})">✏ Editar</button>
            <button class="card-btn" onclick="deleteCard(${c.id})" style="background:rgba(220,38,38,0.3)">✕ Excluir</button>
          </div>
        </div>`;
    });
    html += `<div class="add-card" onclick="openModal('modal-card')"><div style="font-size:24px">＋</div><div style="font-size:13px;font-weight:500">Adicionar cartão</div></div>`;
    grid.innerHTML = html;
  }

  function openEditCard(id) {
    const c = cards.find(x => x.id === id);
    document.getElementById('edit-card-id').value = id;
    document.getElementById('edit-card-name').value = c.name;
    document.getElementById('edit-card-limit').value = c.limit;
    document.getElementById('edit-card-close').value = c.close;
    document.getElementById('edit-card-due').value = c.due;
    // marca a cor selecionada
    document.querySelectorAll('#edit-card-colors .color-dot').forEach(d => {
      d.classList.toggle('selected', d.dataset.color === c.color);
    });
    openModal('modal-card-edit');
  }

  function saveEditCard() {
    const id = parseInt(document.getElementById('edit-card-id').value);
    const c = cards.find(x => x.id === id);
    c.name  = document.getElementById('edit-card-name').value || c.name;
    c.limit = parseFloat(document.getElementById('edit-card-limit').value) || c.limit;
    c.close = parseInt(document.getElementById('edit-card-close').value) || c.close;
    c.due   = parseInt(document.getElementById('edit-card-due').value) || c.due;
    const sel = document.querySelector('#edit-card-colors .color-dot.selected');
    if (sel) c.color = sel.dataset.color;
    renderCards();
    closeModal('modal-card-edit');
    showToast('Cartão atualizado!');
  }

  function deleteCard(id) {
    if (!confirm('Excluir este cartão?')) return;
    cards = cards.filter(x => x.id !== id);
    renderCards();
    showToast('Cartão excluído.');
  }

  // Modal novo cartão
  let newCardColor = '#7c3aed,#5b21b6';
  document.querySelectorAll('#modal-card .color-dot').forEach(d => {
    d.addEventListener('click', function() {
      document.querySelectorAll('#modal-card .color-dot').forEach(x => x.classList.remove('selected'));
      this.classList.add('selected');
      const clr = this.style.background;
      // deriva gradiente simples
      newCardColor = clr + ',' + clr;
    });
  });
  document.querySelectorAll('#edit-card-colors .color-dot').forEach(d => {
    d.addEventListener('click', function() {
      document.querySelectorAll('#edit-card-colors .color-dot').forEach(x => x.classList.remove('selected'));
      this.classList.add('selected');
    });
  });

  document.querySelector('#modal-card .btn-save').onclick = function() {
    const name  = document.querySelector('#modal-card input[type=text]').value.trim();
    const limit = parseFloat(document.querySelector('#modal-card input[type=number]').value) || 0;
    const closeInputs = document.querySelectorAll('#modal-card input[type=number]');
    const closeDay = parseInt(closeInputs[1]?.value) || 15;
    const dueDay   = parseInt(closeInputs[2]?.value) || 22;
    if (!name) { showToast('Informe o nome do cartão'); return; }
    const sel = document.querySelector('#modal-card .color-dot.selected');
    const clr = sel ? sel.style.background + ',' + sel.style.background : '#7c3aed,#5b21b6';
    cards.push({ id: nextCardId++, name, limit, spent: 0, close: closeDay, due: dueDay, color: clr });
    renderCards();
    closeModal('modal-card');
    showToast('Cartão criado!');
  };

  // ══════════════════════════════════════════
  // METAS
  // ══════════════════════════════════════════
  function renderGoals() {
    const grid = document.getElementById('goals-grid');
    let html = '';
    goals.forEach(g => {
      const pct = Math.min(100, Math.round((g.current / g.target) * 100));
      const falta = g.target - g.current;
      let statusClass, statusIcon, statusTxt;
      if (pct >= 100)       { statusClass='status-done'; statusIcon='🚀'; statusTxt='Concluída! Meta atingida!'; }
      else if (pct >= 50)   { statusClass='status-ok';   statusIcon='✓';  statusTxt=`No ritmo certo! · Faltam ${fmt(falta)}`; }
      else                  { statusClass='status-warn';  statusIcon='⚠';  statusTxt=`Abaixo do esperado · Faltam ${fmt(falta)}`; }
      const pctClass = pct>=100?'goal-pct-done': pct>=50?'goal-pct-ok':'goal-pct-warn';
      const fillClass = pct>=100?'goal-fill-done': pct>=50?'goal-fill-ok':'goal-fill-warn';
      const valueColor = pct>=100?'#2563eb': '#16a34a';
      const typeLabel = g.type === 'economy' ? '💰 Economia' : '🎯 Controle de gastos';
      const months = g.monthly > 0 ? Math.ceil(falta / g.monthly) : '∞';
      html += `
        <div class="goal-card">
          <div class="goal-card-header"><span class="goal-card-name">${g.name}</span><span class="${pctClass}">${pct}%</span></div>
          <div class="goal-type-txt">${typeLabel}</div>
          <div class="goal-card-track"><div class="goal-card-fill ${fillClass}" style="width:${pct}%"></div></div>
          <div class="goal-card-values"><span style="color:${valueColor};font-weight:600">${fmt(g.current)}</span><span style="color:#adb5bd">meta: ${fmt(g.target)}</span></div>
          <div class="goal-card-status ${statusClass}">${statusIcon} ${statusTxt}<div style="font-size:11px;margin-top:3px;opacity:.8">Prazo: ${g.date ? new Date(g.date).toLocaleDateString('pt-BR') : '—'}</div></div>
          <div class="sim-box"><div class="sim-label">Simulação: se eu guardar por mês</div>
            <div class="sim-row">
              <input class="sim-input" type="number" value="${g.monthly}" onchange="simGoal(this,${g.target},${g.current})" />
              <span class="sim-result">→ ${months} meses</span>
            </div>
          </div>
          <div class="goal-actions">
            <button class="btn-edit" style="flex:1" onclick="openEditGoal(${g.id})">✏ Editar</button>
            <button class="btn-del"  style="flex:1" onclick="deleteGoal(${g.id})">✕ Excluir</button>
          </div>
        </div>`;
    });
    html += `<div class="goal-add" onclick="openModal('modal-goal')"><div style="font-size:26px">＋</div><div style="font-size:13px;font-weight:500">Nova meta</div></div>`;
    grid.innerHTML = html;
    updateGoalsStats();
  }

  function simGoal(input, target, current) {
    const monthly = parseFloat(input.value) || 0;
    const falta = target - current;
    const months = monthly > 0 ? Math.ceil(falta / monthly) : '∞';
    input.nextElementSibling.textContent = `→ ${months} meses`;
  }

  function updateGoalsStats() {
    document.getElementById('gs-total').textContent = goals.length;
    document.getElementById('gs-ok').textContent = goals.filter(g => (g.current/g.target) >= 0.5).length;
    document.getElementById('gs-warn').textContent = goals.filter(g => (g.current/g.target) < 0.5).length;
    const total = goals.reduce((s,g) => s + g.current, 0);
    document.getElementById('gs-saved').textContent = fmt(total);
  }

  function openEditGoal(id) {
    const g = goals.find(x => x.id === id);
    document.getElementById('edit-goal-id').value = id;
    document.getElementById('edit-goal-name').value = g.name;
    document.getElementById('edit-goal-target').value = g.target;
    document.getElementById('edit-goal-current').value = g.current;
    document.getElementById('edit-goal-date').value = g.date;
    document.getElementById('edit-goal-monthly').value = g.monthly;
    setEditGoalType(g.type);
    openModal('modal-goal-edit');
  }

  function setEditGoalType(type) {
    document.getElementById('edit-type-economy').className = 'type-btn' + (type==='economy' ? ' t-savings' : '');
    document.getElementById('edit-type-control').className = 'type-btn' + (type==='control' ? ' t-purple'  : '');
    document.getElementById('edit-goal-id').dataset.type = type;
  }

  function saveEditGoal() {
    const id = parseInt(document.getElementById('edit-goal-id').value);
    const g = goals.find(x => x.id === id);
    g.name    = document.getElementById('edit-goal-name').value || g.name;
    g.target  = parseFloat(document.getElementById('edit-goal-target').value) || g.target;
    g.current = parseFloat(document.getElementById('edit-goal-current').value) || 0;
    g.date    = document.getElementById('edit-goal-date').value || g.date;
    g.monthly = parseFloat(document.getElementById('edit-goal-monthly').value) || g.monthly;
    g.type    = document.getElementById('edit-goal-id').dataset.type || g.type;
    renderGoals();
    closeModal('modal-goal-edit');
    showToast('Meta atualizada!');
  }

  function deleteGoal(id) {
    if (!confirm('Excluir esta meta?')) return;
    goals = goals.filter(x => x.id !== id);
    renderGoals();
    showToast('Meta excluída.');
  }

  document.querySelector('#modal-goal .btn-save').onclick = function() {
    const name    = document.querySelector('#modal-goal input[type=text]').value.trim();
    const inputs  = document.querySelectorAll('#modal-goal input[type=number]');
    const target  = parseFloat(inputs[0]?.value) || 0;
    const current = parseFloat(inputs[1]?.value) || 0;
    const monthly = parseFloat(inputs[3]?.value) || 0;
    const dateEl  = document.querySelector('#modal-goal input[type=date]');
    const date    = dateEl?.value || '';
    if (!name) { showToast('Informe o nome da meta'); return; }
    const typeOk = document.querySelector('#modal-goal .type-btn.t-savings');
    goals.push({ id: nextGoalId++, name, type: typeOk ? 'economy' : 'control', target, current, date, monthly });
    renderGoals();
    closeModal('modal-goal');
    showToast('Meta criada!');
  };

  // ══════════════════════════════════════════
  // CATEGORIAS
  // ══════════════════════════════════════════
  function renderCats(filter) {
    currentCatFilter = filter || currentCatFilter;
    const grid = document.getElementById('cats-grid');
    const list = categories.filter(c =>
      currentCatFilter === 'all' ||
      (currentCatFilter === 'income'  && c.type === 'income') ||
      (currentCatFilter === 'expense' && c.type === 'expense')
    );
    let html = '';
    list.forEach(c => {
      const typeBadge = c.type === 'income' ? '<span class="cat-type-badge badge-income">Receita</span>'
                      : c.type === 'expense' ? '<span class="cat-type-badge badge-expense">Despesa</span>'
                      : '<span class="cat-type-badge badge-both">Ambos</span>';
      const subsHtml = c.subs.length === 0
        ? `<div style="font-size:12px;color:#adb5bd;padding:4px 0">Nenhuma subcategoria ainda</div>`
        : c.subs.map((s,i) => `
            <div class="subcat-item" id="sub-${c.id}-${i}">
              <span class="subcat-name"><span class="subcat-arrow">└</span>${s}</span>
              <button class="btn-del-sm" onclick="deleteSubcat(${c.id},'${s.replace(/'/g,"\\'")}')">✕</button>
            </div>`).join('');
      html += `
        <div class="cat-card" id="cat-${c.id}">
          <div class="cat-header">
            <div class="cat-left" onclick="toggleCatSub(${c.id})">
              <div class="cat-icon-box" style="background:${c.color}18">${c.icon}</div>
              <div>
                <div class="cat-name">${c.name} ${typeBadge}</div>
                <div class="cat-meta" id="cat-meta-${c.id}">${c.txCount} transações · ${c.subs.length} subcategoria${c.subs.length !== 1 ? 's' : ''}</div>
              </div>
            </div>
            <div class="actions">
              <button class="btn-edit" onclick="openEditCat(${c.id})">✏ Editar</button>
              <button class="btn-del"  onclick="deleteCat(${c.id})">✕ Excluir</button>
            </div>
          </div>
          <div class="cat-bar-row">
            <div class="cat-bar-track"><div class="cat-bar-fill" style="background:${c.color};width:${c.pct}%"></div></div>
            <span class="cat-bar-pct">${c.pct}%</span>
          </div>
          <button class="expand-btn" id="expand-btn-${c.id}" onclick="toggleCatSub(${c.id})">▸ Ver subcategorias</button>
          <div class="subcats" id="subs-${c.id}">
            ${subsHtml}
            <div class="subcat-add">
              <input class="subcat-input" id="subinput-${c.id}" placeholder="Nova subcategoria..." onkeydown="if(event.key==='Enter')addSubcatById(${c.id})" />
              <button class="btn-add-sub" onclick="addSubcatById(${c.id})">+</button>
            </div>
          </div>
        </div>`;
    });
    html += `<div class="cat-add" onclick="openModal('modal-cat')"><div style="font-size:22px">＋</div><div style="font-size:13px;font-weight:500">Nova categoria</div></div>`;
    grid.innerHTML = html;
  }

  function filterCats(filter, btn) {
    document.querySelectorAll('#cat-type-tabs .type-tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderCats(filter);
  }

  function toggleCatSub(id) {
    const el = document.getElementById('subs-' + id);
    const btn = document.getElementById('expand-btn-' + id);
    el.classList.toggle('open');
    btn.textContent = el.classList.contains('open') ? '▾ Ocultar subcategorias' : '▸ Ver subcategorias';
  }

  function addSubcatById(catId) {
    const input = document.getElementById('subinput-' + catId);
    const name = input.value.trim();
    if (!name) return;
    const cat = categories.find(c => c.id === catId);
    if (cat.subs.includes(name)) { showToast('Subcategoria já existe'); return; }
    cat.subs.push(name);
    renderCats();
    showToast('Subcategoria adicionada!');
    // reabre o painel
    setTimeout(() => {
      const el = document.getElementById('subs-' + catId);
      if (el) { el.classList.add('open'); document.getElementById('expand-btn-' + catId).textContent = '▾ Ocultar subcategorias'; }
    }, 10);
  }

  function deleteSubcat(catId, name) {
    const cat = categories.find(c => c.id === catId);
    cat.subs = cat.subs.filter(s => s !== name);
    renderCats();
    showToast('Subcategoria removida.');
    setTimeout(() => {
      const el = document.getElementById('subs-' + catId);
      if (el) { el.classList.add('open'); document.getElementById('expand-btn-' + catId).textContent = '▾ Ocultar subcategorias'; }
    }, 10);
  }

  function openEditCat(id) {
    const c = categories.find(x => x.id === id);
    document.getElementById('edit-cat-id').value = id;
    document.getElementById('edit-cat-name').value = c.name;
    document.getElementById('edit-cat-type').value = c.type;
    document.querySelectorAll('#edit-cat-colors .color-dot').forEach(d => {
      d.classList.toggle('selected', d.dataset.color === c.color);
    });
    document.querySelectorAll('#edit-cat-icons .icon-opt').forEach(opt => {
      opt.classList.toggle('selected', opt.textContent === c.icon);
    });
    openModal('modal-cat-edit');
  }

  function saveEditCat() {
    const id = parseInt(document.getElementById('edit-cat-id').value);
    const c = categories.find(x => x.id === id);
    c.name = document.getElementById('edit-cat-name').value || c.name;
    c.type = document.getElementById('edit-cat-type').value;
    const selColor = document.querySelector('#edit-cat-colors .color-dot.selected');
    if (selColor) c.color = selColor.dataset.color;
    const selIcon = document.querySelector('#edit-cat-icons .icon-opt.selected');
    if (selIcon) c.icon = selIcon.textContent;
    renderCats();
    closeModal('modal-cat-edit');
    showToast('Categoria atualizada!');
  }

  function deleteCat(id) {
    if (!confirm('Excluir esta categoria?')) return;
    categories = categories.filter(x => x.id !== id);
    renderCats();
    showToast('Categoria excluída.');
  }

  // Ícone picker no modal de edição
  document.querySelectorAll('#edit-cat-icons .icon-opt').forEach(opt => {
    opt.addEventListener('click', () => {
      document.querySelectorAll('#edit-cat-icons .icon-opt').forEach(o => o.classList.remove('selected'));
      opt.classList.add('selected');
    });
  });
  document.querySelectorAll('#edit-cat-colors .color-dot').forEach(d => {
    d.addEventListener('click', () => {
      document.querySelectorAll('#edit-cat-colors .color-dot').forEach(x => x.classList.remove('selected'));
      d.classList.add('selected');
    });
  });

  // Nova categoria via modal
  document.querySelector('#modal-cat .btn-save').onclick = function() {
    const name = document.querySelector('#modal-cat input[type=text]').value.trim();
    const type = document.querySelector('#modal-cat select').value === 'Receita' ? 'income'
               : document.querySelector('#modal-cat select').value === 'Ambos' ? 'both' : 'expense';
    if (!name) { showToast('Informe o nome da categoria'); return; }
    const selColor = document.querySelector('#modal-cat .color-dot.selected');
    const color = selColor ? selColor.style.background : '#16a34a';
    const selIcon = document.querySelector('#modal-cat .icon-opt.selected');
    const icon = selIcon ? selIcon.textContent : '💼';
    categories.push({ id: nextCatId++, name, type, color, icon, pct: 0, txCount: 0, subs: [] });
    renderCats();
    closeModal('modal-cat');
    showToast('Categoria criada!');
  };

  // ══════════════════════════════════════════
  // Period buttons (genérico)
  // ══════════════════════════════════════════
  document.querySelectorAll('.periods').forEach(group => {
    group.querySelectorAll('.period-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        group.querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
      });
    });
  });

  document.querySelectorAll('.type-tabs:not(#cat-type-tabs)').forEach(group => {
    group.querySelectorAll('.type-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        group.querySelectorAll('.type-tab').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
      });
    });
  });

  document.querySelectorAll('.fatura-tabs').forEach(group => {
    group.querySelectorAll('.fatura-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        group.querySelectorAll('.fatura-tab').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
      });
    });
  });

  document.querySelectorAll('.color-picker').forEach(picker => {
    picker.querySelectorAll('.color-dot').forEach(dot => {
      dot.addEventListener('click', () => {
        picker.querySelectorAll('.color-dot').forEach(d => d.classList.remove('selected'));
        dot.classList.add('selected');
      });
    });
  });

  document.querySelectorAll('.icon-picker').forEach(picker => {
    picker.querySelectorAll('.icon-opt').forEach(opt => {
      opt.addEventListener('click', () => {
        picker.querySelectorAll('.icon-opt').forEach(o => o.classList.remove('selected'));
        opt.classList.add('selected');
      });
    });
  });

  // ══════════════════════════════════════════
  // PROJEÇÃO DE SALDO
  // ══════════════════════════════════════════

  let projMonths = 6;

  // Despesas fixas: { id, icon, name, value }
  let fixedExpenses = [
    { id: 1, icon: '🏠', name: 'Aluguel',       value: 1200 },
    { id: 2, icon: '💡', name: 'Contas (luz/água/net)', value: 380 },
    { id: 3, icon: '📱', name: 'Celular',        value: 80  },
    { id: 4, icon: '🏋️', name: 'Academia',       value: 120 },
  ];
  let nextFixedId = 5;

  // Parcelas: { id, icon, name, value, remaining } (remaining = parcelas restantes)
  let installments = [
    { id: 1, icon: '💊', name: 'Consulta médica (Nubank)', value: 100, remaining: 2 },
    { id: 2, icon: '🎮', name: 'PS5 – parcelado',          value: 250, remaining: 8 },
    { id: 3, icon: '🛍️', name: 'Geladeira (Itaú)',         value: 190, remaining: 5 },
  ];
  let nextInstId = 4;

  function selectMonths(n, btn) {
    projMonths = n;
    document.querySelectorAll('.proj-m-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderProjection();
  }

  function renderFixedList() {
    const el = document.getElementById('fixed-list');
    if (!fixedExpenses.length) {
      el.innerHTML = '<div class="proj-empty">Nenhuma despesa fixa cadastrada</div>';
      document.getElementById('fixed-total').textContent = fmt(0);
      return;
    }
    el.innerHTML = fixedExpenses.map(f => `
      <div class="proj-item">
        <div class="proj-item-icon">${f.icon}</div>
        <div class="proj-item-info">
          <div class="proj-item-name">${f.name}</div>
          <div class="proj-item-sub">Mensal</div>
        </div>
        <div class="proj-item-val">${fmt(f.value)}</div>
        <button class="proj-item-del" onclick="deleteFixed(${f.id})" title="Remover">✕</button>
      </div>`).join('');
    const total = fixedExpenses.reduce((s,f) => s + f.value, 0);
    document.getElementById('fixed-total').textContent = fmt(total);
  }

  function renderInstList() {
    const el = document.getElementById('installment-list');
    if (!installments.length) {
      el.innerHTML = '<div class="proj-empty">Nenhuma parcela cadastrada</div>';
      document.getElementById('inst-total').textContent = fmt(0);
      return;
    }
    el.innerHTML = installments.map(i => `
      <div class="proj-item">
        <div class="proj-item-icon">${i.icon}</div>
        <div class="proj-item-info">
          <div class="proj-item-name">${i.name}</div>
          <div class="proj-item-sub">${i.remaining} parcela${i.remaining !== 1 ? 's' : ''} restante${i.remaining !== 1 ? 's' : ''} · ${fmt(i.value)}/mês</div>
        </div>
        <div class="proj-item-val">${fmt(i.value * i.remaining)}</div>
        <button class="proj-item-del" onclick="deleteInst(${i.id})" title="Remover">✕</button>
      </div>`).join('');
    const total = installments.reduce((s,i) => s + i.value * i.remaining, 0);
    document.getElementById('inst-total').textContent = fmt(total);
  }

  function deleteFixed(id) {
    fixedExpenses = fixedExpenses.filter(f => f.id !== id);
    renderFixedList();
    renderProjection();
  }

  function deleteInst(id) {
    installments = installments.filter(i => i.id !== id);
    renderInstList();
    renderProjection();
  }

  function addFixedExpense() {
    const name  = prompt('Nome da despesa fixa:');
    if (!name) return;
    const val   = parseFloat(prompt('Valor mensal (R$):'));
    if (isNaN(val) || val <= 0) { showToast('Valor inválido'); return; }
    const icons = ['🏠','💡','📱','🍔','🚗','💊','📚','🎉','💼','🌱','🏋️','🛍️'];
    const icon  = icons[Math.floor(Math.random() * icons.length)];
    fixedExpenses.push({ id: nextFixedId++, icon, name, value: val });
    renderFixedList();
    renderProjection();
    showToast('Despesa fixa adicionada!');
  }

  function addInstallment() {
    const name      = prompt('Nome da parcela:');
    if (!name) return;
    const val       = parseFloat(prompt('Valor por parcela (R$):'));
    if (isNaN(val) || val <= 0) { showToast('Valor inválido'); return; }
    const remaining = parseInt(prompt('Quantas parcelas restam?'));
    if (isNaN(remaining) || remaining <= 0) { showToast('Número inválido'); return; }
    const icons = ['💊','🎮','🛍️','✈️','📱','🏋️','🎓','🚗'];
    const icon  = icons[Math.floor(Math.random() * icons.length)];
    installments.push({ id: nextInstId++, icon, name, value: val, remaining });
    renderInstList();
    renderProjection();
    showToast('Parcela adicionada!');
  }

  function renderProjection() {
    const startBalance = parseFloat(document.getElementById('proj-balance').value) || 0;
    const monthlyIncome = parseFloat(document.getElementById('proj-income').value) || 0;
    const now = new Date();

    // Monta dados mês a mês
    const rows = [];
    let balance = startBalance;

    for (let m = 0; m < projMonths; m++) {
      const d = new Date(now.getFullYear(), now.getMonth() + m + 1, 1);
      const label = d.toLocaleDateString('pt-BR', { month: 'short', year: '2-digit' });
      const labelFull = d.toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' });

      const fixedTotal = fixedExpenses.reduce((s,f) => s + f.value, 0);

      // Parcelas: só conta se ainda tiver parcelas neste mês
      const instTotal = installments.reduce((s,i) => {
        return s + (i.remaining > m ? i.value : 0);
      }, 0);

      const totalOut = fixedTotal + instTotal;
      const openingBalance = balance;
      balance = balance + monthlyIncome - totalOut;

      rows.push({ label, labelFull, opening: openingBalance, income: monthlyIncome, fixed: fixedTotal, inst: instTotal, totalOut, closing: balance });
    }

    // ── Stats cards ──
    const lastBalance = rows.length ? rows[rows.length-1].closing : startBalance;
    const minBalance  = Math.min(...rows.map(r => r.closing));
    const totalFixedAll = rows.reduce((s,r) => s + r.fixed, 0);
    const totalInstAll  = rows.reduce((s,r) => s + r.inst, 0);

    document.getElementById('proj-stats').innerHTML = `
      <div class="stat-card">
        <div class="stat-label">Saldo em ${projMonths} meses</div>
        <div class="stat-value" style="color:${lastBalance >= 0 ? 'var(--income)' : 'var(--expense)'}">${fmt(lastBalance)}</div>
        <div class="stat-sub">${lastBalance >= startBalance ? '▲ crescimento' : '▼ queda'} vs hoje</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Menor saldo no período</div>
        <div class="stat-value" style="color:${minBalance >= 0 ? 'var(--text)' : 'var(--expense)'}">${fmt(minBalance)}</div>
        <div class="stat-sub">${minBalance < 0 ? '⚠ saldo negativo!' : 'dentro do limite'}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total despesas fixas</div>
        <div class="stat-value" style="color:var(--warn)">${fmt(totalFixedAll)}</div>
        <div class="stat-sub">em ${projMonths} meses</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total parcelas</div>
        <div class="stat-value" style="color:var(--expense)">${fmt(totalInstAll)}</div>
        <div class="stat-sub">comprometido</div>
      </div>`;

    // ── Gráfico ──
    const maxVal = Math.max(...rows.map(r => Math.max(r.income, r.totalOut, Math.abs(r.closing))), 1);
    const H = 160;
    const chartHtml = rows.map(r => {
      const hInc  = Math.round((r.income   / maxVal) * H);
      const hOut  = Math.round((r.totalOut / maxVal) * H);
      const hSal  = Math.round((Math.abs(r.closing) / maxVal) * H);
      const salColor = r.closing >= 0 ? 'var(--primary)' : 'var(--expense)';
      return `<div class="proj-bar-group">
        <div class="proj-bars">
          <div class="proj-bar" style="height:${hInc}px;background:var(--income);width:16px" title="Receitas: ${fmt(r.income)}"></div>
          <div class="proj-bar" style="height:${hOut}px;background:var(--expense);width:16px" title="Saídas: ${fmt(r.totalOut)}"></div>
          <div class="proj-bar" style="height:${Math.max(hSal,3)}px;background:${salColor};width:16px;opacity:0.85" title="Saldo: ${fmt(r.closing)}"></div>
        </div>
      </div>`;
    }).join('');
    const xHtml = rows.map(r =>
      `<div style="flex:1;text-align:center;font-size:10px;color:var(--text-soft);white-space:nowrap">${r.label}</div>`
    ).join('');
    document.getElementById('proj-chart').innerHTML = chartHtml;
    document.getElementById('proj-chart-x').innerHTML = xHtml;
    document.getElementById('proj-chart').style.justifyContent = projMonths <= 6 ? 'center' : 'flex-start';

    // ── Tabela ──
    const tbody = document.getElementById('proj-tbody');
    tbody.innerHTML = rows.map(r => {
      const rowClass = r.closing < 0 ? 'proj-row-neg' : r.closing < startBalance * 0.3 ? 'proj-row-warn' : 'proj-row-ok';
      return `<tr class="${rowClass}">
        <td style="font-weight:600;color:var(--text)">${r.labelFull}</td>
        <td style="color:var(--text-mid)">${fmt(r.opening)}</td>
        <td style="color:var(--income);font-weight:600">+${fmt(r.income)}</td>
        <td style="color:var(--warn)">${fmt(r.fixed)}</td>
        <td style="color:var(--expense)">${fmt(r.inst)}</td>
        <td style="color:var(--expense);font-weight:600">${fmt(r.totalOut)}</td>
        <td style="font-family:'Lora',serif;font-weight:700;font-size:14px">${fmt(r.closing)}</td>
      </tr>`;
    }).join('');
  }

  // ══════════════════════════════════════════
  // INICIALIZAÇÃO
  // ══════════════════════════════════════════
  renderCards();
  renderGoals();
  renderCats();
  renderFixedList();
  renderInstList();
  renderProjection();
</script>
</div><!-- /app-screen -->

<script>
  // ═══════════════════════════════════════════════════════
  // CONFIGURAÇÃO SUPABASE
  // Substitua pelos valores do seu projeto em supabase.com
  // ═══════════════════════════════════════════════════════
  const SUPABASE_URL = 'https://ewqvucgjvolefayearjp.supabase.co';
  const SUPABASE_ANON_KEY = 'sb_publishable_adZwVyxCVF-Bwdmd8mG07w_eD0XCc3z';

  // Inicializa o cliente Supabase
  const { createClient } = supabase;
  const _supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

  // Verifica se as credenciais foram configuradas
  const credenciaisConfiguradas =
    SUPABASE_URL !== 'https://SEU-PROJETO.supabase.co' &&
    SUPABASE_ANON_KEY !== 'sua-chave-anonima-aqui';

  if (!credenciaisConfiguradas) {
    document.getElementById('config-notice').style.display = 'block';
  } else {
    document.getElementById('config-notice').style.display = 'none';
  }

  // Alterna entre abas Login / Criar conta
  function switchTab(tab) {
    document.getElementById('tab-login').classList.toggle('active', tab === 'login');
    document.getElementById('tab-signup').classList.toggle('active', tab === 'signup');
    document.getElementById('form-login').style.display = tab === 'login' ? 'block' : 'none';
    document.getElementById('form-signup').style.display = tab === 'signup' ? 'block' : 'none';
    clearMessages();
  }

  function showError(msg) {
    const el = document.getElementById('login-error');
    el.textContent = msg;
    el.style.display = 'block';
    document.getElementById('login-success').style.display = 'none';
  }

  function showSuccess(msg) {
    const el = document.getElementById('login-success');
    el.textContent = msg;
    el.style.display = 'block';
    document.getElementById('login-error').style.display = 'none';
  }

  function clearMessages() {
    document.getElementById('login-error').style.display = 'none';
    document.getElementById('login-success').style.display = 'none';
  }

  // Entra com e-mail + senha
  async function handleLogin() {
    if (!credenciaisConfiguradas) {
      showError('Configure as credenciais do Supabase primeiro (veja o aviso acima).');
      return;
    }
    const email = document.getElementById('login-email').value.trim();
    const password = document.getElementById('login-password').value;
    if (!email || !password) { showError('Preencha e-mail e senha.'); return; }

    const btn = document.getElementById('btn-login');
    btn.disabled = true;
    btn.textContent = 'Entrando...';

    const { data, error } = await _supabase.auth.signInWithPassword({ email, password });

    btn.disabled = false;
    btn.textContent = 'Entrar';

    if (error) { showError(error.message); return; }
    entrarNoApp(data.user);
  }

  // Cria conta nova
  async function handleSignup() {
    if (!credenciaisConfiguradas) {
      showError('Configure as credenciais do Supabase primeiro (veja o aviso acima).');
      return;
    }
    const email = document.getElementById('signup-email').value.trim();
    const password = document.getElementById('signup-password').value;
    if (!email || !password) { showError('Preencha e-mail e senha.'); return; }
    if (password.length < 6) { showError('A senha precisa ter ao menos 6 caracteres.'); return; }

    const btn = document.getElementById('btn-signup');
    btn.disabled = true;
    btn.textContent = 'Criando conta...';

    const { data, error } = await _supabase.auth.signUp({ email, password });

    btn.disabled = false;
    btn.textContent = 'Criar conta';

    if (error) { showError(error.message); return; }
    showSuccess('Conta criada! Verifique seu e-mail para confirmar o cadastro.');
  }

  // Login com Google (OAuth)
  async function handleGoogle() {
    if (!credenciaisConfiguradas) {
      showError('Configure as credenciais do Supabase primeiro.');
      return;
    }
    await _supabase.auth.signInWithOAuth({
      provider: 'google',
      options: { redirectTo: window.location.href }
    });
  }

  // Logout
  async function handleLogout() {
    await _supabase.auth.signOut();
    document.getElementById('app-screen').style.display = 'none';
    document.getElementById('login-screen').style.display = 'flex';
  }

  // Mostra o app e preenche o avatar com iniciais do e-mail
  function entrarNoApp(user) {
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('app-screen').style.display = 'block';
    const email = user.email || '';
    document.getElementById('user-email-display').textContent = email;
    document.getElementById('user-avatar').textContent = email.charAt(0).toUpperCase();
  }

  // Ao carregar a página, verifica se já existe sessão ativa
  (async () => {
    if (!credenciaisConfiguradas) return; // sem credenciais, fica na tela de login
    const { data } = await _supabase.auth.getSession();
    if (data.session) {
      entrarNoApp(data.session.user);
    }
    // Escuta mudanças de estado (login/logout em outra aba, etc.)
    _supabase.auth.onAuthStateChange((event, session) => {
      if (session) {
        entrarNoApp(session.user);
      } else {
        document.getElementById('app-screen').style.display = 'none';
        document.getElementById('login-screen').style.display = 'flex';
      }
    });
  })();
</script>
</body>
</html>
